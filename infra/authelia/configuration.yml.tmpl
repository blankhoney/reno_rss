---
server:
  address: tcp://0.0.0.0:9091
  asset_path: /config/assets

log:
  level: info

authentication_backend:
  password_reset:
    disable: true     # MVP: 禁用密码重置，避免 jwt_secret 依赖
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id

totp:
  issuer: my_rss

webauthn:
  disable: false

access_control:
  default_policy: deny
  rules:
    - domain:
        - 'staging-ai-reader.${DOMAIN}'
      subject:
        - ['group:demo']
      policy: one_factor
    - domain:
        - 'reader.${DOMAIN}'
        - 'ai-reader.${DOMAIN}'
        - 'staging-reader.${DOMAIN}'
      subject:
        - ['group:demo']
      policy: deny
    - domain:
        - 'reader.${DOMAIN}'
        - 'ai-reader.${DOMAIN}'
        - 'staging-reader.${DOMAIN}'
        - 'staging-ai-reader.${DOMAIN}'
      policy: two_factor

session:
  name: authelia_session
  same_site: lax
  inactivity: 30m
  expiration: 8h
  remember_me: 7d
  cookies:
    - domain: '${DOMAIN}'
      authelia_url: 'https://auth.${DOMAIN}'
      default_redirection_url: 'https://reader.${DOMAIN}'

storage:
  local:
    path: /config/db.sqlite3

notifier:
  smtp:
    host: ${SMTP_HOST}
    port: ${SMTP_PORT}
    username: ${SMTP_USER}
    password: ${SMTP_PASSWORD}
    sender: "my_rss <${SMTP_SENDER}>"
    # Resend 使用标准 STARTTLS，tls.skip_verify 保持 false
    tls:
      skip_verify: false
