---
server:
  address: tcp://0.0.0.0:9091

log:
  level: info

authentication_backend:
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id

totp:
  issuer: my_rss

webauthn:
  disable: false

access_control:
  default_policy: deny
  rules:
    - domain:
        - 'reader.${DOMAIN}'
        - 'staging-reader.${DOMAIN}'
      policy: two_factor

session:
  name: authelia_session
  same_site: lax
  inactivity: 30m
  expiration: 8h
  remember_me: 7d
  cookies:
    - domain: '${DOMAIN}'
      authelia_url: 'https://auth.${DOMAIN}'
      default_redirection_url: 'https://reader.${DOMAIN}'

storage:
  local:
    path: /config/db.sqlite3

# MVP: 验证码写到文件而非发邮件
# 查看: docker exec myrss-prod-authelia-1 cat /config/notification.txt
notifier:
  filesystem:
    filename: /config/notification.txt
