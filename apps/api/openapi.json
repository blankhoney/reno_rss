  "components": {
    "schemas": {
      "ArticleStateRequest": {
        "properties": {
          "status": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^(read|unread|skipped)$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status"
          },
          "saved": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Saved"
          },
          "read_progress": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 1.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Read Progress"
          }
        },
        "type": "object",
        "title": "ArticleStateRequest"
      },
      "AskRequest": {
        "properties": {
          "question": {
            "type": "string",
            "maxLength": 1000,
            "minLength": 1,
            "title": "Question"
          },
          "selected_text": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 5000
              },
              {
                "type": "null"
              }
            ],
            "title": "Selected Text"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "question"
        ],
        "title": "AskRequest"
      },
      "CreateFeedRequest": {
        "properties": {
          "feed_url": {
            "type": "string",
            "maxLength": 2048,
            "minLength": 1,
            "title": "Feed Url"
          },
          "category_id": {
