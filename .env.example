DOMAIN=example.com

# Optional on VPS: keep real Authelia users outside tracked repo files.
# Example: /root/opt/myrss/secrets/users_database.yml
AUTHELIA_USERS_DATABASE_FILE=../authelia/users_database.yml

# Optional for CI/CD remote image deploys. LOCAL_BUILD=1 keeps local build mode.
IMAGE_REGISTRY=
READER_WEB_IMAGE=
SCORER_WORKER_IMAGE=

MINIFLUX_ADMIN=admin
MINIFLUX_ADMIN_PASSWORD=change_me

DEMO_LANDING_ENABLED=true
DEMO_USERNAME=demo
DEMO_PASSWORD=change_me
DEMO_AUTHELIA_BASE_URL=http://authelia-prod:9091
DEMO_TARGET_URL=https://staging-ai-reader.example.com/?module=all&sort=default&lang=zh
DEMO_ALLOWED_ORIGIN=https://staging-ai-reader.example.com

POSTGRES_SUPERUSER_PASSWORD=change_me
POSTGRES_MINIFLUX_PASSWORD=change_me
POSTGRES_SCORING_PASSWORD=change_me

# keep change_me in sync with POSTGRES_MINIFLUX_PASSWORD
MINIFLUX_DATABASE_URL=postgres://miniflux:change_me@postgres:5432/miniflux?sslmode=disable
# keep change_me in sync with POSTGRES_SCORING_PASSWORD
SCORING_DATABASE_URL=postgres://scoring:change_me@postgres:5432/scoring?sslmode=disable

MINIFLUX_API_BASE_URL=http://miniflux:8080
MINIFLUX_API_KEY=change_me
SCORER_TENANT_ID=default
SCORER_PORT=8000
SCORER_WEBHOOK_USERNAME=scorer
SCORER_WEBHOOK_PASSWORD=change_me
SCORER_WEBHOOK_MAX_ENTRIES=20

READER_TENANT_ID=default
READER_MINIFLUX_USER_ID=1
SCORING_SERVICE_URL=http://scorer-worker:8000
WEB_SEARCH_PROVIDER=none
WEB_SEARCH_API_KEY=change_me

MINIMAX_API_KEY=change_me
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
LLM_TIMEOUT_SECONDS=30

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=change_me
SMTP_SENDER=noreply@blankhoney.xyz
